$p=(netsh wlan show profiles)|Select-String "\:(.+)$"|ForEach-Object {$_.Matches.Groups.Value.Trim()}; Write-Host "`nNázev Wi-Fi`t`t`t| Heslo`n--------------------------------------------" -ForegroundColor Cyan; foreach($s in $p){if($s -and $s -notmatch "Všichni"){$d=netsh wlan show profile name="$s" key=clear;$h=$d|Select-String "Obsah klíče|Key Content";if($h){$v=($h -split ":").Trim()}else{$v="[Bez hesla]"}; "{0,-25} | {1}" -f $s, $v}}
